package com.awscore.autenticacionservice.infrastructure.mapper;

import com.awscore.autenticacionservice.domain.model.User;
import com.awscore.autenticacionservice.infrastructure.entity.UserEntity;
import org.mapstruct.Mapper;
import org.mapstruct.Mapping;
import org.mapstruct.factory.Mappers;

@Mapper
public interface UserMapper {
    UserMapper INSTANCE = Mappers.getMapper(UserMapper.class);

    @Mapping(source = "numIdentification", target = "numIdentification")
    @Mapping(source = "email", target = "email")
    @Mapping(source = "password", target = "password")
    @Mapping(source = "fullPhone", target = "fullPhone")
    @Mapping(source = "active", target = "active")
    UserEntity toEntity(User dto);

    @Mapping(source = "numIdentification", target = "numIdentification")
    @Mapping(source = "email", target = "email")
    @Mapping(source = "password", target = "password")
    @Mapping(source = "fullPhone", target = "fullPhone")
    @Mapping(source = "active", target = "active")
    User toDto(UserEntity entity);

    // Si es necesario mapear Device, se agregaría un método de mapeo para la clase Device:
    // DeviceMapper deviceMapper = Mappers.getMapper(DeviceMapper.class);
    // @Mapping(source = "device", target = "device")
}
