import org.springframework.data.annotation.Id;
import org.springframework.data.relational.core.mapping.Table;
import org.springframework.data.relational.core.mapping.Column;
import lombok.Getter;
import lombok.Setter;
import java.util.Objects;

@Table("user")
@Getter
@Setter
public class UserEntity {

    @Id
    private Long id;

    @Column("num_identification")
    private String numIdentification;

    @Column("email")
    private String email;

    @Column("password")
    private String password;

    @Column("full_phone")
    private String fullPhone;

    @Column("active")
    private boolean active;

    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        UserEntity that = (UserEntity) o;
        return id.equals(that.id) && active == that.active && Objects.equals(numIdentification, that.numIdentification) && Objects.equals(email, that.email) && Objects.equals(password, that.password) && Objects.equals(fullPhone, that.fullPhone);
    }

    @Override
    public int hashCode() {
        return Objects.hash(id, numIdentification, email, password, fullPhone, active);
    }
}
