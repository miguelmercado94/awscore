package com.awscore.documentservice.domain.infrastructure.adapter;

import java.io.ByteArrayInputStream;
import java.io.InputStream;

import org.springframework.stereotype.Service;

import com.awscore.documentservice.domain.model.FileS3;

import software.amazon.awssdk.services.s3.S3Client;
import software.amazon.awssdk.services.s3.model.GetObjectRequest;
import software.amazon.awssdk.services.s3.model.PutObjectRequest;
import software.amazon.awssdk.core.sync.RequestBody;

import lombok.RequiredArgsConstructor;
import reactor.core.publisher.Mono;

@Service
@RequiredArgsConstructor
public class S3Adapter implements S3Repository {

    private final S3Client s3Client;

    @Override
    public Mono<String> uploadFile(FileS3 fileS3, String bucketName) {
        return Mono.fromCallable(() -> {
            InputStream inputStream = new ByteArrayInputStream(fileS3.getDataByte());

            String key = fileS3.getLocationURL() + "/" + fileS3.getFileFullName();

            PutObjectRequest putObjectRequest = PutObjectRequest.builder()
                    .bucket(bucketName)
                    .key(key)
                    .build();

            s3Client.putObject(putObjectRequest, RequestBody.fromInputStream(inputStream, fileS3.getDataByte().length));

            return key;
        });
    }

    @Override
    public Mono<FileS3> downloadFile(String key, String bucketName) {
        return Mono.fromCallable(() -> {
            GetObjectRequest getObjectRequest = GetObjectRequest.builder()
                    .bucket(bucketName)
                    .key(key)
                    .build();

            InputStream inputStream = s3Client.getObject(getObjectRequest);
            byte[] data = inputStream.readAllBytes();

            // Extraer información adicional si es necesario
            String fileFullName = key.substring(key.lastIndexOf('/') + 1);
            String locationURL = key.substring(0, key.lastIndexOf('/'));

            return FileS3.builder()
                    .fileFullName(fileFullName)
                    .locationURL(locationURL)
                    .dataByte(data)
                    .build();
        });
    }

}
