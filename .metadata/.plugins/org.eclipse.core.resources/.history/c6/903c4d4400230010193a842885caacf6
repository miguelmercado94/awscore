import org.springframework.data.annotation.Id;
import org.springframework.data.relational.core.mapping.Table;
import org.springframework.data.relational.core.mapping.Column;
import lombok.Getter;
import lombok.Setter;
import java.util.Objects;

@Table("token")
@Getter
@Setter
public class TokenEntity {

    public enum TokenType {
        BEARER
    }

    @Id
    private Long id;

    @Column("token")
    private String token;

    @Column("token_type")
    private TokenType tokenType = TokenType.BEARER;

    @Column("revoked")
    private boolean revoked;

    @Column("expired")
    private boolean expired;

    @Column("user_id")
    private Long userId;

    @Column("device_id")
    private Long deviceId;

    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        TokenEntity token1 = (TokenEntity) o;
        return id.equals(token1.id) && revoked == token1.revoked && expired == token1.expired && Objects.equals(token, token1.token) && tokenType == token1.tokenType && Objects.equals(userId, token1.userId) && Objects.equals(deviceId, token1.deviceId);
    }

    @Override
    public int hashCode() {
        return Objects.hash(id, token, tokenType, revoked, expired, userId, deviceId);
    }
}
