package com.awscore.documentservice.config;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

import lombok.RequiredArgsConstructor;

@RestController
@RequestMapping("/api/upload")
@RequiredArgsConstructor
public class FileUploadController {

    private final FileUploadService fileUploadService;



    @PostMapping
    public String uploadFile(@RequestBody FileUploadRequest request) {
        String fileName = request.getFileName();
        String base64Content = request.getBase64Content();

        return fileUploadService.uploadFile(fileName, base64Content);
    }
}
